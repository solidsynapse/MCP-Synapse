{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "MCP Synapse",
    "version":  "0.6.0-rc.1",
    "identifier":  "com.solidsynapse.mcpsynapse",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "MCP Synapse",
                                    "width":  1180,
                                    "height":  760,
                                    "minWidth":  1180,
                                    "minHeight":  760
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
