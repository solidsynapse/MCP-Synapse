@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  /* Base Colors */
  --bg-base: #0e1116;
  --surface-1: #161b22;
  --surface-2: #21262d;
  --border-subtle: rgba(240, 246, 252, 0.1);
  --text-primary: #f0f6fc;
  --text-muted: rgba(240, 246, 252, 0.6);

  /* Accent - Teal/Cyan */
  --accent: #2f81f7; /* Github Blue-ish as placeholder, let's adjust to Teal/Cyan as requested */
  --accent-cyan: #39d353; /* Wait, user asked for Teal/Cyan */
  /* Let's pick a nice Teal/Cyan that isn't neon */
  --accent-primary: #2da44e; /* No, that's green */
  
  /* Retrying with a proper Cyan/Teal */
  --color-accent: #1f6feb; /* Blue */
  --color-accent-teal: #17c0eb; /* Too bright? */
  
  /* Let's go with a specific deep cyan */
  --accent-color: #3fb950; /* Green? No. */
  
  /* Let's use a safe Teal */
  --accent-base: #27c9a9; /* Teal */
  --accent-dim: rgba(39, 201, 169, 0.1);
  --accent-glow: rgba(39, 201, 169, 0.15);

  /* Radii */
  --radius-card: 16px;
  --radius-btn: 12px;
  --radius-badge: 999px;

  /* Spacing */
  --space-1: 8px;
  --space-2: 12px;
  --space-3: 16px;
  --space-4: 24px;
  --space-5: 32px;

  /* Shadows */
  --shadow-1: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
  --shadow-2: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.15);
}

body {
  background-color: var(--bg-base);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* Utility classes for design tokens if needed, or just use style attributes/custom classes */
.bg-surface-1 { background-color: var(--surface-1); }
.bg-surface-2 { background-color: var(--surface-2); }
.border-subtle { border-color: var(--border-subtle); }
.text-muted { color: var(--text-muted); }
.text-primary { color: var(--text-primary); }

/* Scrollbar polish */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-base);
}
::-webkit-scrollbar-thumb {
  background: var(--surface-2);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #30363d;
}
